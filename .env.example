# ─────────────────────────────────────────────────────────────────────────
# Job Outreach Dashboard — environment variables
# Copy this file to .env.local for local development. Never commit real
# secrets — this file only documents which variables the app reads.
# ─────────────────────────────────────────────────────────────────────────

# App mode. Set to "demo" to run without Firebase/Notion/Gmail configured
# (uses mock/demo data and skips real sends). Leave unset in production.
NEXT_PUBLIC_APP_MODE=

# Public URL of this deployment. Used to build absolute links (e.g. the
# email open-tracking pixel). Falls back to Vercel's VERCEL_URL, then to
# the production domain if neither is set.
NEXT_PUBLIC_APP_URL=

# ─── Firebase (auth + per-user credential storage) ─────────────────────────
# Full JSON service account key, as a single-line string.
FIREBASE_SERVICE_ACCOUNT=

# ─── Notion (platform-level fallback; per-user values are stored encrypted
#      in Firestore and take precedence when Firebase is configured) ───────
NOTION_API_KEY=
NOTION_DB_ID=

# ─── AI providers ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# "anthropic" or "groq"
PREFERRED_LLM_PROVIDER=anthropic

# ─── Gmail (per-user OAuth send credentials; platform fallback below) ──────
GMAIL_USER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Platform-level OAuth app used to initiate the Gmail connect flow in Settings
GMAIL_PLATFORM_CLIENT_ID=
GMAIL_PLATFORM_CLIENT_SECRET=

# ─── Storage ─────────────────────────────────────────────────────────────
# Vercel Blob read/write token, used for resume uploads/downloads.
BLOB_READ_WRITE_TOKEN=

# ─── Cron ────────────────────────────────────────────────────────────────
# Shared secret required by all /api/cron/* routes (checked against the
# Authorization header Vercel Cron sends).
CRON_SECRET=
